# ============================================
# Cyberia — Environment Variables
# ============================================
# Copy this to .env and fill in your keys.
# Bun loads .env automatically. Vite loads .env files in dev/build.
#
# To use: cp .env.example .env
# ============================================

# ── Tavily Web Search (Runtime) ───────────
# Get a free API key: https://tavily.com
# Required for the AI web_search tool.
VITE_TAVILY_API_KEY=YOUR_TAVILY_API_KEY_HERE

# ── OpenRouter (Integration Tests Only) ───
# Not needed at runtime — key is typed in the UI, model is selected from dropdown.
# Only required when running src/tests/ai/api-integration.test.ts
# Note: no VITE_ prefix — these are read by Bun tests, not by Vite browser code.
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY_HERE
OPENROUTER_MODEL=openai/gpt-4o

# ── Contact Email (Display Only) ─────────
# Shown in the settings dialog footer.
VITE_CONTACT_EMAIL=support@cyberiaspace.app
